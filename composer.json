{
  "name": "wesleysimplicio/sistema-sindico",
  "description": "Condominium management system in pure PHP + MySQL.",
  "type": "project",
  "require": {},
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "files": [
      "src/Core/Env.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/unit/"
    }
  },
  "scripts": {
    "test:unit": "vendor/bin/phpunit --configuration phpunit.xml.dist --testdox"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
