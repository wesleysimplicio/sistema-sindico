APP_NAME="Sistema Sindico"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sistema_sindico
DB_USERNAME=root
DB_PASSWORD=

# Reserved for future auth tokens / mobile app
APP_KEY=
JWT_SECRET=

# Transactional email
MAIL_DRIVER=log
MAIL_FROM=no-reply@sindico.local
MAIL_FROM_NAME="Sistema Sindico"
MAIL_API_KEY=
MAIL_API_BASE_URL=https://api.resend.com
MAIL_TIMEOUT_SECONDS=10

# Rate limiting
RATE_LIMIT_DRIVER=mysql
REDIS_URL=redis://127.0.0.1:6379/0
